{
  "manifest_version": 3,
  "name": "XTEC-Esfera",
  "description": "Shows a centered overlay with XTEC-Esfera module grade summaries.",
  "version": "0.1.1",
  "action": {
    "default_title": "XTEC-Esfera",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.xtec.cat/*",
        "https://*.gencat.cat/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "scripting"
  ]
}
