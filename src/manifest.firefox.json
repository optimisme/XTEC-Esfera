{
  "manifest_version": 3,
  "name": "XTEC-Esfera",
  "description": "Obre un panell d'edició de qualificacions de mòduls d'XTEC-Esfera.",
  "version": "0.1.1",
  "action": {
    "default_title": "XTEC-Esfera",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.xtec.cat/*",
        "https://*.gencat.cat/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "xtec-esfera@optimisme.github.io",
      "strict_min_version": "109.0"
    }
  }
}
